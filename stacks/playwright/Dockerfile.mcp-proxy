FROM mcr.microsoft.com/playwright:v1.58.0-noble
RUN apt-get update -qq && apt-get install -y -qq python3 python3-pip python3-venv > /dev/null 2>&1 && \
    python3 -m venv /opt/venv && \
    /opt/venv/bin/pip install --quiet mcp-proxy 2>&1 | tail -1 && \
    npm install -g @playwright/mcp 2>&1 | tail -1
ENV PATH="/opt/venv/bin:$PATH"
ENTRYPOINT ["python3", "-m", "mcp_proxy", "--port", "8099", "--host", "0.0.0.0", "--stateless", "--", "playwright-mcp", "--browser", "chromium", "--headless"]
