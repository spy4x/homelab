{
  "tasks": {
    "start": "deno run --allow-net --allow-env --allow-read --allow-write +main.ts",
    "check": "deno check +main.ts"
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false,
    "proseWrap": "preserve",
    "semiColons": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "exclude": ["require-await"]
    }
  }
}
