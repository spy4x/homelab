{
  "tasks": {
    "build": "deno run -A +build.ts",
    "check": "deno check src/main.tsx"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false,
    "proseWrap": "preserve",
    "semiColons": false
  },
  "lint": {
    "rules": { "tags": ["recommended"], "exclude": ["require-await"] }
  }
}
